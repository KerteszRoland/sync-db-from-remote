# Remote database connection
REMOTE_DB_HOST=
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=
REMOTE_DB_USER=
REMOTE_DB_PASSWORD=

# Move previous seed.dump to backup/ before each sync (true/false)
BACKUP_PREVIOUS_DUMP=false
# DUMP_BACKUP_DIR=./backup

# Local Docker database
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=localdb
POSTGRES_DB=mydb

# Variables for post-init.sql substitution
DEV_API_URL=myapiurl